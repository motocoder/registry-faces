# Copy this file to `.env` (which is gitignored) and fill in the values
# you actually use. The CLI loads `.env` automatically on startup.
#
# Shell-set environment variables always win over the file — the file is just
# a convenient default. Variables you don't need can stay commented out.

# ---------------------------------------------------------------------------
# Default provider + model overrides
#
# REGISTRY_FACES_PROVIDER picks which preset to use when --provider is not
# passed on the command line. Run `registry-faces providers` to see all
# available presets and their defaults.
# ---------------------------------------------------------------------------

# REGISTRY_FACES_PROVIDER=gemini
# REGISTRY_FACES_MODEL=gemini-2.0-flash
# REGISTRY_FACES_BASE_URL=http://localhost:11434/v1

# ---------------------------------------------------------------------------
# Provider credentials
#
# Set only the ones you actually use. Each provider preset only needs its
# own key; missing keys for unused providers don't cause errors.
# ---------------------------------------------------------------------------

# Anthropic (Claude) — paid
# ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini) — free tier at https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AI...

# OpenAI — paid
# OPENAI_API_KEY=sk-...

# Groq — free tier at https://console.groq.com
# GROQ_API_KEY=gsk_...

# Cerebras — free tier at https://cloud.cerebras.ai
# CEREBRAS_API_KEY=csk-...

# OpenRouter — free models available at https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-...

# GitHub Models — free tier; use a GitHub personal access token
# GITHUB_TOKEN=ghp_...

# Ollama needs no key — it runs locally on http://localhost:11434

# ---------------------------------------------------------------------------
# Cloudflare R2 — only needed by scripts/upload_shards.py
#
# Used to ship the packaged shard bundles to the bucket the registry-
# recognizer Android client reads from. Mint a token in the Cloudflare
# dashboard with Object Read+Write scope on the shards bucket. The same
# key set works for the registry-recognizer Gradle ./gradlew uploadShards
# task (its local.properties uses the same key names).
# ---------------------------------------------------------------------------

# R2_BASE_URL=https://<account_id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# SHARDS_BUCKET=registry-recognizer/shards/
# SHARDS_FOLDER=./shards   # optional; defaults to ./shards under the project root
