# Python build / packaging
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/

# Secrets — never commit
.env
/.env.local

# IDEs
.idea/
.vscode/

# Test / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS junk
.DS_Store

# Local data (large, personal, regenerable). Output of scrapers /
# packagers — registry/ is the per-state record tree, registry-runs/
# the scratch dir from one ingest pass, shards/ the packaged uploads.
# All three are derivable; nothing here belongs in version control.
/registry/
/registry-runs/
/shards/
/shards_*/

identity-store/
